# ── Banco de Dados ────────────────────────────────────────────────────────────
# Ao rodar com Docker Compose, use "postgres" como host (nome do service)
DB_URL=jdbc:postgresql://postgres:5432/mydatabase
DB_USERNAME=myuser
DB_PASSWORD=secret

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere uma chave segura: openssl rand -base64 64
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_segura
JWT_EXPIRATION_MS=86400000

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Crie seu bot em https://t.me/BotFather
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN_AQUI
TELEGRAM_BOT_USERNAME=SeuBotUsername_bot

# ── News API ──────────────────────────────────────────────────────────────────
# Cadastro gratuito em https://newsapi.org
NEWS_API_KEY=SUA_NEWS_API_KEY_AQUI

# ── Stock API (Massive / Polygon-compatible) ───────────────────────────────────
STOCK_TOKEN=SEU_STOCK_TOKEN_AQUI

